{
  "name": "playwright-bdd-cucumber",
  "version": "1.0.0",
  "description": "BDD Testing with Playwright + Cucumber.js",
  "scripts": {
    "test": "bddgen && playwright test",
    "test:headed": "bddgen && playwright test --headed",
    "test:chrome": "bddgen && playwright test --project=chromium",
    "test:firefox": "bddgen && playwright test --project=firefox",
    "test:safari": "bddgen && playwright test --project=webkit",
    "test:report": "playwright show-report",
    "test:debug": "bddgen && playwright test --debug"
  },
  "cucumber": {
    "default": {
      "features": "features/**/*.feature",
      "require": [
        "features/**/*.js"
      ],
      "format": [
        "progress-bar",
        "json:reports/cucumber-report.json"
      ],
      "formatOptions": {
        "snippetInterface": "async-await"
      },
      "publishQuiet": true
    }
  },
  "devDependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "^1.44.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "multiple-cucumber-html-reporter": "^3.7.0",
    "playwright": "^1.44.0",
    "playwright-bdd": "^8.5.0"
  }
}